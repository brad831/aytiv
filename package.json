{
  "name": "copilot",
  "version": "1.0.0",
  "description": "AI mixing companion for Ableton Live",
  "main": "main.js",
  "scripts": {
    "start": "concurrently -k \"npm run build:watch\" \"npm run electron:start\"",
    "build:watch": "webpack --watch --mode development",
    "electron:start": "wait-on dist/bundle.js && electron .",
    "build": "webpack --mode production",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^16.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.24.5",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.1",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "style-loader": "^4.0.0",
    "wait-on": "^7.2.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  },
  "build": {
    "appId": "co.bradfrere.copilot",
    "productName": "Copilot",
    "mac": {
      "target": "dmg",
      "arch": ["arm64"],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Copilot needs microphone access for voice input.",
        "NSScreenCaptureUsageDescription": "Copilot needs screen recording access to analyze your Ableton session."
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*",
      "dist/**/*",
      ".env",
      "node_modules/**/*"
    ]
  }
}
